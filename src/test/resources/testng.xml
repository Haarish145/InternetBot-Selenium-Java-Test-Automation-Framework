<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="InternetBot Suite" thread-count="2" parallel="tests">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>
    <test name="The Internet Herokuapp Tests">
        <classes>
            <class name="tests.AuthenticationTest"/>
            <class name="tests.JavaScriptAlertsTest"/>
            <class name="tests.CheckboxesAndDropdownsTest"/>
            <class name="tests.FileUploadTest"/>
            <class name="tests.DynamicLoadingTest"/>
        </classes>
    </test>
</suite>
